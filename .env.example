# GitHub Personal Access Token (optional, increases rate limit from 60 to 5000 req/h)
GITHUB_TOKEN=

# Anthropic API Key (required if AI_ENABLED=true)
ANTHROPIC_API_KEY=

# Enable AI features (query translation, description summarization, README translation)
AI_ENABLED=false

# Base URL for OGP metadata (set to your deployment URL in production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
